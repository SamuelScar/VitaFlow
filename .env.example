# Ambiente local do VitaFlow.
#
# Este arquivo serve como referencia para criar o `.env` usado pelo Docker Compose.
# O arquivo `.env` da raiz tambem e montado dentro do container em `/var/www/html/.env`,
# entao as variaveis abaixo configuram tanto os containers quanto o Laravel.

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------

# Porta HTTP exposta pelo container da aplicacao.
# A aplicacao fica acessivel em http://localhost:8080.
APP_PORT=8080

# Porta exposta pelo Vite dev server.
# Usada apenas durante desenvolvimento dos assets.
VITE_PORT=5173

# Inicia o Vite automaticamente junto com o container da aplicacao.
# Use `false` se preferir rodar `npm run dev` manualmente dentro do container.
RUN_VITE_DEV=true

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Porta do PostgreSQL exposta na maquina local.
POSTGRES_PORT=5432

# Banco, usuario e senha criados pelo container do PostgreSQL.
# Estes valores precisam bater com as variaveis DB_* usadas pelo Laravel.
POSTGRES_DB=vitaflow
POSTGRES_USER=vitaflow
POSTGRES_PASSWORD=vitaflow

# -----------------------------------------------------------------------------
# Laravel
# -----------------------------------------------------------------------------

# Nome exibido pela aplicacao.
APP_NAME=VitaFlow

# Ambiente local de desenvolvimento.
APP_ENV=local

# Chave de criptografia do Laravel.
# Gere uma chave e cole aqui antes de usar o sistema.
# Exemplo: docker compose exec app php artisan key:generate --show
APP_KEY=

# Exibe detalhes de erro em desenvolvimento.
# Em producao, usar false.
APP_DEBUG=true

# URL publica usada pelo Laravel para gerar links.
APP_URL=http://localhost:8080

# Idioma padrao da aplicacao e das mensagens de validacao.
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

# -----------------------------------------------------------------------------
# Banco de dados usado pelo Laravel
# -----------------------------------------------------------------------------

# Driver PostgreSQL.
DB_CONNECTION=pgsql

# Nome do servico do banco no docker-compose.yml.
# Dentro do Docker, o host e `db`, nao `localhost`.
DB_HOST=db

# Porta interna do PostgreSQL dentro da rede Docker.
DB_PORT=5432

# Credenciais usadas pelo Laravel para conectar no PostgreSQL.
DB_DATABASE=vitaflow
DB_USERNAME=vitaflow
DB_PASSWORD=vitaflow

# -----------------------------------------------------------------------------
# Drivers internos do Laravel
# -----------------------------------------------------------------------------

# Guarda sessoes no banco de dados.
SESSION_DRIVER=database

# -----------------------------------------------------------------------------
# Envio de e-mails com Resend
# -----------------------------------------------------------------------------

# Crie uma chave em https://resend.com/api-keys.
MAIL_MAILER=resend
RESEND_API_KEY=

# Use onboarding@resend.dev apenas para testes enviados ao e-mail da conta
# Resend. Para outros destinatarios, use um endereco de um dominio verificado.
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME=VitaFlow
